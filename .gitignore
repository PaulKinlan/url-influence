node_modules/
.env
.env.*
# results/raw/ is the intermediate (one JSON per model call). It stays OUT of the
# repo; the committed results/transcript.jsonl.gz is the complete, auditable record.
results/raw/
results/judge-cache/
# RUNLOG.md is the human-browsable mirror of transcript.jsonl.gz — same content,
# but too large to commit. Generated locally via `npm run transcript`.
results/RUNLOG.md
# The uncompressed transcript is replaced by the committed .gz.
results/transcript.jsonl
*.log
.DS_Store

# ...but the run console log IS part of the committed audit trail, so un-ignore
# it explicitly (the *.log glob above would otherwise catch it).
!results/run.log
results/ranks.csv
